generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  PREMIUM
  ADMIN
}

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique

  firstName  String?
  lastName   String?
  imageUrl   String?

  role       Role     @default(USER)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}